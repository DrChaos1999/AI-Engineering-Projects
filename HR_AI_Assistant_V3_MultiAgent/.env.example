# Never commit real keys. Rotate any key that has ever been pasted into source code.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Current defaults as of July 2026; change these if your account uses other model IDs.
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_MODEL=claude-sonnet-5
DEEPSEEK_MODEL=deepseek-v4-flash
JUDGE_PROVIDER=openai

MODEL_TIMEOUT_SECONDS=90
MAX_OUTPUT_TOKENS=900
RETRIEVAL_CHUNKS=8
MAX_UPLOAD_MB=20

# Anonymous development session.
DEFAULT_SESSION_MINUTES=10
DEFAULT_MAX_QUESTIONS=10

# For customer-specific limits, enable access codes and define:
# code:minutes:max_questions,code:minutes:max_questions
REQUIRE_ACCESS_CODE=false
CUSTOMER_PLANS=customer5:5:5,customer10:10:10
SESSION_COOKIE_NAME=hr_session
ACCESS_CODE_PEPPER=replace-with-a-long-random-server-secret
COOKIE_SECURE=false

# Set this in production so customers cannot upload documents.
ADMIN_UPLOAD_TOKEN=

# Blank = local stdio MCP server launched automatically.
# For a separately deployed Streamable HTTP MCP server, set its /mcp URL.
MCP_SERVER_URL=
DIRECT_RETRIEVAL_FALLBACK=true
PARALLEL_CANDIDATES=true

# Used only when running mcp_server.py as a separate HTTP/SSE process.
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8001
